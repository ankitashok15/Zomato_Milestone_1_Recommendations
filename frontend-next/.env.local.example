# =============================================================================
# Mode A — FastAPI (local default): full form + /api/backend proxy
# =============================================================================
BACKEND_URL=http://127.0.0.1:8010
# NEXT_PUBLIC_BACKEND_MODE=fastapi   ← default if omitted

# Optional nav link to Streamlit:
# NEXT_PUBLIC_STREAMLIT_APP_URL=https://zomatorecommendations.streamlit.app

# =============================================================================
# Mode B — Streamlit as recommender (Vercel + Streamlit Cloud, no FastAPI)
# =============================================================================
# NEXT_PUBLIC_BACKEND_MODE=streamlit
# NEXT_PUBLIC_STREAMLIT_APP_URL=https://zomatorecommendations.streamlit.app
# BACKEND_URL can be omitted or left dummy; Home uses Streamlit launch panel.

# =============================================================================
# Vercel (Root Directory: frontend-next)
# • Streamlit + Next “connected”: set Mode B vars (Production + Preview), redeploy.
# • Full Next form: Mode A with real FastAPI BACKEND_URL, NEXT_PUBLIC_BACKEND_MODE=fastapi or unset.
